# Neura Card Studio — Variables de entorno
# Todas son opcionales. La app funciona sin keys (modo local).

# Fecha/hora de inicio del evento (ISO 8601 con offset de zona horaria)
# Ejemplo Perú UTC-5: 2026-05-25T18:30:00-05:00
NEXT_PUBLIC_EVENT_UNLOCK_AT=2026-05-25T18:30:00-05:00

# Supabase — requerido para el muro en tiempo real
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # opcional, para bypass RLS desde server
# SUPABASE_WALL_BUCKET=wall-images   # default: wall-images

# AI — requerido para generación de retratos neurales
# Opción A: Vercel AI Gateway (preferido, multi-proveedor)
AI_GATEWAY_API_KEY=...
# AI_GATEWAY_IMAGE_MODEL=google/gemini-3-pro-image
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Opción B: OpenAI directo (fallback automático si Gateway falla)
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1536
